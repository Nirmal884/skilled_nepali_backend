// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String         @id @default(uuid())
  email           String         @unique
  fullName        String
  password        String
  country         Int
  role            Role           @default(JOBSEEKER)
  phone           String?        @default("")
  jobCategories   JobCategory[]  @relation("UserJobCategories")
  applicantTypeId String?
  applicantType   ApplicantType? @relation(fields: [applicantTypeId], references: [id])
  experience      Float?
  pastExperience  String?
  resume          String?
  companyName     String?
  designation     String?
  companyLogo     String?
  centreName      String?
  centreLogo      String?
  jobs            Jobs[]
  isAdminApproved Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  @@map("user_profiles")
}

model JobCategory {
  id           String    @id @default(uuid())
  categoryName String    @unique
  users        User[]    @relation("UserJobCategories")
  jobs         Jobs[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  @@map("job_categories")
}

model ApplicantType {
  id                String    @id @default(uuid())
  applicantTypeName String    @unique
  users             User[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  @@map("applicant_types")
}

model Jobs {
  id                      String              @id @default(uuid())
  title                   String
  type                    JobType
  country                 Int
  location                String
  jobCategoryId           String
  jobCategory             JobCategory         @relation(fields: [jobCategoryId], references: [id])
  minSalary               Float               @default(0)
  maxSalary               Float
  currency                String              @default("QAR")
  experience              String?
  description             String?
  requirements            String[]            @default([])
  benefits                String[]            @default([])
  responsibilities        String[]            @default([])
  deadLine                DateTime?
  isUrgent                Boolean             @default(false)
  noOfOpenings            Int                 @default(1)
  userId                  String
  user                    User                @relation(fields: [userId], references: [id])
  isAdminApprovedDeletion Boolean             @default(false)
  adminApprovalStatus     AdminApprovalStatus @default(PENDING)
  deletionReason          String?             @default("")
  deleteRequestedOn       DateTime?           @default(now())
  adminApprovedOn         DateTime?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  deletedAt               DateTime?

  @@map("jobs")
}

enum Role {
  JOBSEEKER
  EMPLOYER
  TRAINING_CENTRE
  ADMIN
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum AdminApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}
